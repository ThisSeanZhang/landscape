{
  "name": "@landscape-router/types",
  "version": "0.13.1",
  "type": "module",
  "exports": {
    "./*": "./src/*"
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*",
        "src/*.d.ts",
        "src/*.ts"
      ]
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "orval",
    "prepublishOnly": "echo 'Run gen_ts_bindings.sh before publishing' && test -f src/api/schemas/index.ts"
  },
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "axios": "^1.13.5",
    "orval": "^8.4.2"
  }
}
